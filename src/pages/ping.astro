---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Ping me">
  <main class="max-w-3xl mx-auto px-4 py-10 space-y-6">
    <h1 class="text-xl font-medium">Ping me</h1>

    <p class="text-gray-700 leading-relaxed">
      If something here feels out of date (or you just want to leave a note), you can send me a quick message.
    </p>

    <form
      name="ping"
      method="POST"
      data-netlify="true"
      data-netlify-honeypot="bot-field"
      action="/ping/thanks"
      class="space-y-4"
    >
      <!-- Required for Netlify to identify the form -->
      <input type="hidden" name="form-name" value="ping" />

      <!-- Honeypot (bots fill this; humans won't see it) -->
      <p class="hidden">
        <label>
          Don't fill this out: <input name="bot-field" />
        </label>
      </p>

      <label class="block space-y-1">
        <span class="text-sm text-gray-700">Your message</span>
        <textarea
          name="message"
          required
          rows="5"
          class="w-full rounded border border-gray-300 p-2"
          placeholder="A quick note…"
        ></textarea>
      </label>

      <label class="block space-y-1">
        <span class="text-sm text-gray-700">Email (optional)</span>
        <input
          type="email"
          name="email"
          class="w-full rounded border border-gray-300 p-2"
          placeholder="Only if you want a reply"
        />
      </label>

      <button type="submit" class="rounded border border-gray-300 px-3 py-2 text-sm">
        Send
      </button>
    </form>
  </main>
</BaseLayout>
