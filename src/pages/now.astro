---
import BaseLayout from "../layouts/BaseLayout.astro";

const lastUpdated = "April 23, 2026";
const signals = [
	{
		label: "On the show",
		copy: "I've put a lot of work into setting up the pod and I have a list of guests I want to invite. Almost there and I'm very excited about it!",
	},
	{
		label: "In writing",
		copy: "After writing a few drafts I'm not feeling the most confident in my writing ability. Looking forward to fixing that.",
	},
	{
		label: "Noticing",
		copy: "I'm noticing the pretty big leap in focus and productivity when I'm not absorbed in a gaming hole. Balance is not a strength of mine.",
	},
];

	const recentChanges = [
		{ date: "Apr 23", note: "Podcast. Website. Podcast. Website. My mantra until it's done." },
		{ date: "Apr 22", note: "I actually published a live (but still draft-ish) version of my site." },
		{ date: "Apr 19", note: "Kept circling the question of what makes a personal site feel lived in." },
	];
---

<BaseLayout
	title="Now | Randy Warner"
	description="A snapshot of what Randy Warner is focused on lately: podcasting, writing, ideas, and whatever is currently tugging at his sleeve."
>
	<main>
		<section class="hero" aria-labelledby="now-title">
			<p class="eyebrow">Now</p>
			<h1 id="now-title">What I'm paying attention to lately.</h1>
			<p class="intro">
				This page is a basic snapshot of me right now. Nothing too deep, just a little peek at what's on my mind,
				what creative things I'm getting into, and what I'm noticing.
			</p>
		</section>

		<section class="main-note" aria-labelledby="main-note-title">
			<p class="eyebrow">Main Note</p>
			<h2 id="main-note-title">
				I've been obsessed with community and the cost of things.
			</h2>
			<p>
				I've sort of been on a weird rager about how much shit costs and what to do about it.
				I'm more talking about the artisan side of things. Want artisan bread? Well you can't afford it.
				Want artisan soap? Well you can't afford it. You want artisan anything, you can't afford it.
			</p>
			<p>
				I've got more thoughts on this, but that's not for here. :)
			</p>
		</section>

		<section class="energy" aria-labelledby="energy-title">
			<div class="section-heading">
				<p class="eyebrow">Current Signals</p>
				<h2 id="energy-title">What’s getting energy.</h2>
			</div>

			<div class="signal-stack">
				{
					signals.map((signal, index) => (
						<article class={`signal signal-${index + 1}`}>
							<p class="signal-label">{signal.label}</p>
							<p>{signal.copy}</p>
						</article>
					))
				}
			</div>
		</section>

		<section class="changes" aria-labelledby="changes-title">
			<div class="section-heading">
				<p class="eyebrow">Recently Changed</p>
				<h2 id="changes-title">Proof of life.</h2>
			</div>

			<div class="change-list">
				{
					recentChanges.map((item) => (
						<article class="change-item">
							<span>{item.date}</span>
							<p>{item.note}</p>
						</article>
					))
				}
			</div>
		</section>

		<section class="closing" aria-labelledby="updated-title">
			<p class="eyebrow">Last Updated</p>
			<h2 id="updated-title">{lastUpdated}</h2>
			<p>This page will change whenever it needs to, not on a strict schedule.</p>
		</section>
	</main>
</BaseLayout>

<style>
	main {
		width: min(1180px, calc(100% - 32px));
		margin: 0 auto;
		padding: clamp(36px, 7vw, 76px) 0 64px;
	}

	.hero,
	.main-note,
	.energy,
	.changes,
	.closing {
		max-width: 860px;
	}

	.main-note,
	.energy,
	.changes,
	.closing {
		margin-top: clamp(38px, 5vw, 60px);
	}

	.energy,
	.changes {
		margin-left: 24px;
	}

	.eyebrow {
		margin: 0 0 14px;
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1,
	h2,
	p {
		text-wrap: pretty;
	}

	h1,
	h2 {
		margin: 0;
		font-family: Georgia, "Times New Roman", serif;
		line-height: 1;
	}

	h1 {
		max-width: 18ch;
		font-size: clamp(2.4rem, 5vw, 4.75rem);
	}

	h2 {
		font-size: clamp(1.55rem, 3vw, 2.6rem);
	}

	.intro,
	.main-note p,
	.signal-copy,
	.change-item p,
	.closing p {
		font-size: 1.08rem;
		line-height: 1.65;
	}

	.intro,
	.closing p {
		max-width: 720px;
		margin: 24px 0 0;
	}

	.main-note {
		padding: clamp(24px, 4vw, 34px);
		border: 3px solid var(--ink);
		background:
			linear-gradient(180deg, rgba(255, 249, 236, 0.96), rgba(255, 249, 236, 0.96)),
			repeating-linear-gradient(
				90deg,
				rgba(217, 75, 61, 0.14) 0 22px,
				transparent 22px 44px
			);
		box-shadow: var(--shadow);
	}

	.main-note h2 {
		max-width: 18ch;
		font-size: clamp(1.9rem, 3.4vw, 3rem);
	}

	.main-note p {
		margin: 18px 0 0;
	}

	.section-heading {
		max-width: 720px;
	}

	.signal-stack {
		display: grid;
		gap: 18px;
		margin-top: 28px;
	}

	.signal {
		padding: 0 0 0 24px;
		border-left: 6px solid var(--blue);
	}

	.signal-label {
		margin: 0 0 6px;
		font-size: 0.86rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.signal p:last-child {
		margin: 0;
	}

	.signal-2 {
		border-left-color: var(--yellow);
	}

	.signal-3 {
		border-left-color: var(--green);
	}

	.change-list {
		display: grid;
		gap: 14px;
		max-width: 820px;
		margin-top: 28px;
	}

	.change-item {
		display: grid;
		grid-template-columns: 78px minmax(0, 1fr);
		gap: 16px;
		padding-top: 14px;
		border-top: 1px solid rgba(32, 23, 19, 0.22);
	}

	.change-item span {
		font-size: 0.85rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.change-item p {
		margin: 0;
	}

	.closing {
		margin-top: clamp(42px, 6vw, 72px);
		padding-top: clamp(24px, 4vw, 32px);
		border-top: 2px solid var(--ink);
	}

	@media (max-width: 560px) {
		main {
			width: min(100% - 24px, 1180px);
		}

		.energy,
		.changes {
			margin-left: 0;
		}

		.change-item {
			grid-template-columns: 1fr;
			gap: 6px;
		}
	}
</style>
