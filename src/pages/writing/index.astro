---
import WritingCard from "../../components/WritingCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedWriting } from "../../lib/writing";

const posts = await getPublishedWriting();

const featured = posts.filter((post) => post.data.featured);
const latest = posts.filter((post) => !post.data.featured);
---

<BaseLayout
	title="Writing | Randy Warner"
	description="Writing by Randy Warner: essays, notes, stories, and lists about life, relationships, spirituality, health, stories, and comedy."
	current="writing"
>
	<main>
			<section class="hero">
				<p class="eyebrow">Writing</p>
				<h1>Essays, notes, stories, and the occasional useful list.</h1>
				<p>
					A place for longer reflections and smaller thoughts about life, relationships,
					spirituality, health, stories, comedy, and whatever keeps asking for words.
				</p>
			</section>

			{
				posts.length === 0 ? (
					<section class="empty-state" aria-labelledby="empty-title">
						<p class="eyebrow">Nothing public yet</p>
						<h2 id="empty-title">The writing room is set up. The first pieces are still being drafted.</h2>
						<p>
							Drafts can now live safely in the content system without appearing on the public site.
							When a piece is ready, moving it to published writing and setting <code>draft: false</code>{" "}
							will make it eligible for this page.
						</p>
					</section>
				) : (
					<>
						{featured.length > 0 && (
							<section class="writing-section" aria-labelledby="featured-title">
								<div class="section-heading">
									<p class="eyebrow">Featured</p>
									<h2 id="featured-title">Start here.</h2>
								</div>
								<div class="post-grid featured-grid">
									{featured.map((post) => (
										<WritingCard post={post} featured />
									))}
								</div>
							</section>
						)}

						<section class="writing-section" aria-labelledby="latest-title">
							<div class="section-heading">
								<p class="eyebrow">Latest</p>
								<h2 id="latest-title">Newest first, because the trail should be easy to follow.</h2>
							</div>
							<div class="post-grid">
								{latest.map((post) => (
									<WritingCard post={post} />
								))}
							</div>
						</section>
					</>
				)
			}
	</main>
</BaseLayout>

<style>
	main {
		width: min(1180px, calc(100% - 32px));
		margin: 0 auto;
		padding: clamp(42px, 8vw, 96px) 0 72px;
	}

	.hero {
		max-width: 920px;
	}

	.eyebrow {
		margin: 0 0 14px;
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		text-wrap: pretty;
	}

	h1,
	h2 {
		margin: 0;
		font-family: Georgia, "Times New Roman", serif;
		line-height: 1;
	}

	h1 {
		font-size: clamp(3rem, 6.4vw, 5.8rem);
	}

	h2 {
		font-size: clamp(2rem, 4vw, 3.6rem);
	}

	.hero > p:not(.eyebrow),
	.empty-state > p {
		font-size: 1.08rem;
		line-height: 1.65;
	}

	.hero > p:not(.eyebrow) {
		max-width: 720px;
		margin: 24px 0 0;
	}

	.empty-state,
	.writing-section {
		margin-top: clamp(48px, 8vw, 92px);
		padding-top: clamp(34px, 6vw, 64px);
		border-top: 2px solid var(--ink);
	}

	.empty-state {
		max-width: 760px;
		padding: clamp(28px, 5vw, 48px);
		border: 3px solid var(--ink);
		background: #fff9ec;
		box-shadow: 8px 8px 0 rgba(32, 23, 19, 0.12);
	}

	code {
		padding: 2px 5px;
		background: var(--paper-deep);
	}

	.section-heading {
		display: grid;
		grid-template-columns: minmax(0, 0.8fr) minmax(240px, 0.55fr);
		gap: clamp(20px, 5vw, 56px);
		align-items: end;
		margin-bottom: 22px;
	}

	.section-heading > .eyebrow {
		grid-column: 1 / -1;
		margin-bottom: -6px;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
	}

	.featured-grid {
		grid-template-columns: minmax(0, 1fr);
	}

	@media (max-width: 860px) {
		.section-heading,
		.post-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 560px) {
		main {
			width: min(100% - 24px, 1180px);
		}

		.empty-state {
			padding: 18px;
		}
	}
</style>
