---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatWritingDate, getPublishedWriting, writingTypeLabel, writingSlug } from "../../lib/writing";

export async function getStaticPaths() {
	const posts = await getPublishedWriting();

	return posts.map((post) => ({
		params: { slug: writingSlug(post) },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | Randy Warner`} description={post.data.description} current="writing">
	<main>
			<a class="back-link" href="/writing/">Back to writing</a>
			<article>
				<header class="post-header">
					<div class="post-meta">
						<span>{writingTypeLabel(post.data.type)}</span>
						<time datetime={post.data.date.toISOString()}>{formatWritingDate(post.data.date)}</time>
					</div>
					<h1>{post.data.title}</h1>
					<p>{post.data.description}</p>
					<div class="topic-list" aria-label="Topics">
						{post.data.topics.map((topic) => <span>{topic}</span>)}
					</div>
				</header>

				<div class="content">
					<Content />
				</div>
			</article>
	</main>
</BaseLayout>

<style>
	main {
		width: min(840px, calc(100% - 32px));
		margin: 0 auto;
		padding: clamp(42px, 8vw, 96px) 0 72px;
	}

	.back-link {
		display: inline-flex;
		margin-bottom: 32px;
		font-weight: 900;
	}

	.post-header {
		padding-bottom: clamp(32px, 6vw, 58px);
		border-bottom: 2px solid var(--ink);
	}

	.post-meta,
	.topic-list {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.post-meta {
		margin-bottom: 18px;
	}

	.post-meta span,
	.topic-list span {
		display: inline-flex;
		width: fit-content;
		padding: 5px 8px;
		border: 1px solid var(--ink);
		color: var(--ink);
		font-size: 0.74rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.post-meta span {
		background: var(--yellow);
	}

	.topic-list span {
		background: #cfe0d0;
	}

	.post-meta time {
		padding: 5px 0;
		font-size: 0.86rem;
		font-weight: 800;
	}

	h1 {
		margin: 0;
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(3rem, 8vw, 6.8rem);
		line-height: 0.98;
		text-wrap: pretty;
	}

	.post-header > p {
		max-width: 680px;
		margin: 24px 0;
		font-size: 1.16rem;
		line-height: 1.65;
	}

	.content {
		padding-top: clamp(30px, 5vw, 52px);
		font-size: 1.08rem;
		line-height: 1.78;
	}

	.content :global(h2),
	.content :global(h3) {
		margin: 2em 0 0.6em;
		line-height: 1.1;
	}

	.content :global(h2) {
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(2rem, 4vw, 3.2rem);
	}

	.content :global(h3) {
		font-size: 1.45rem;
	}

	.content :global(p),
	.content :global(ul),
	.content :global(ol),
	.content :global(blockquote) {
		margin: 0 0 1.25em;
	}

	.content :global(blockquote) {
		padding-left: 1rem;
		border-left: 4px solid var(--ink);
		font-family: Georgia, "Times New Roman", serif;
		font-size: 1.35rem;
		line-height: 1.45;
	}

	@media (max-width: 560px) {
		main {
			width: min(100% - 24px, 1180px);
		}
	}
</style>
