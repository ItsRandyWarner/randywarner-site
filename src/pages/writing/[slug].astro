---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Comments from "../../components/Comments.astro";
import { formatWritingDate, getAllWriting, getPublishedWriting, writingTypeLabel, writingSlug } from "../../lib/writing";

export async function getStaticPaths() {
	const posts = import.meta.env.DEV ? await getAllWriting() : await getPublishedWriting();

	return posts.map((post) => ({
		params: { slug: writingSlug(post) },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
	title={`${post.data.title} | Randy Warner`}
	description={post.data.description}
	current="writing"
	type="article"
	image={post.data.image?.src}
>
	<main>
			<a class="back-link" href="/writing/">Back to writing</a>
			<article>
				<header class="post-header">
					<div class="post-meta">
						<span>{writingTypeLabel(post.data.type)}</span>
						{post.data.draft && <span class="draft-label">Draft</span>}
						<time datetime={post.data.date.toISOString()}>{formatWritingDate(post.data.date)}</time>
					</div>
					<h1>{post.data.title}</h1>
					<p>{post.data.description}</p>
					<div class="topic-list" aria-label="Topics">
						{post.data.topics.map((topic) => <span>{topic}</span>)}
					</div>
				</header>

				{
					post.data.image && (
						<figure class="featured-image">
							<img src={post.data.image.src} alt={post.data.image.alt} />
						</figure>
					)
				}

				<div class="content">
					<Content />
				</div>
			</article>
			<Comments postSlug={writingSlug(post)} />
	</main>
</BaseLayout>

<style>
	main {
		width: min(780px, calc(100% - 32px));
		margin: 0 auto;
		padding: clamp(42px, 8vw, 96px) 0 72px;
	}

	.back-link {
		display: inline-flex;
		margin-bottom: 32px;
		font-weight: 900;
	}

	.post-header {
		padding-bottom: clamp(32px, 6vw, 58px);
		border-bottom: 2px solid var(--ink);
	}

	:global(.featured-image) {
		aspect-ratio: 16 / 9;
		max-height: 440px;
		margin: clamp(30px, 5vw, 52px) 0 0;
		overflow: hidden;
		border: 2px solid var(--ink);
		background:
			repeating-linear-gradient(-18deg, rgba(32, 23, 19, 0.08) 0 3px, transparent 3px 17px),
			var(--paper-deep);
		box-shadow: 8px 8px 0 rgba(32, 23, 19, 0.12);
	}

	:global(.featured-image img) {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.post-meta,
	.topic-list {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.post-meta {
		margin-bottom: 18px;
	}

	.post-meta span,
	.topic-list span {
		display: inline-flex;
		width: fit-content;
		padding: 5px 8px;
		border: 1px solid var(--ink);
		color: var(--ink);
		font-size: 0.74rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.post-meta span {
		background: var(--yellow);
	}

	.post-meta .draft-label {
		background: #f4d9df;
	}

	.topic-list span {
		background: #cfe0d0;
	}

	.post-meta time {
		padding: 5px 0;
		font-size: 0.86rem;
		font-weight: 800;
	}

	h1 {
		margin: 0;
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(2.15rem, 4.7vw, 4.1rem);
		line-height: 0.98;
		text-wrap: pretty;
	}

	.post-header > p {
		max-width: 680px;
		margin: 24px 0;
		font-size: 1.16rem;
		line-height: 1.65;
	}

	.content {
		padding-top: clamp(30px, 5vw, 52px);
		font-size: 1.08rem;
		line-height: 1.78;
	}

	.content :global(h2),
	.content :global(h3) {
		margin: 2em 0 0.6em;
		line-height: 1.1;
	}

	.content :global(h2) {
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(1.75rem, 3vw, 2.65rem);
	}

	.content :global(h3) {
		font-size: 1.45rem;
	}

	.content :global(p),
	.content :global(ul),
	.content :global(ol),
	.content :global(blockquote) {
		margin: 0 0 1.25em;
	}

	.content :global(blockquote) {
		padding-left: 1rem;
		border-left: 4px solid var(--ink);
		font-family: Georgia, "Times New Roman", serif;
		font-size: 1.35rem;
		line-height: 1.45;
	}

	.content :global(mark) {
		padding: 0 0.14em;
		background: linear-gradient(transparent 42%, rgba(246, 198, 76, 0.72) 42%);
		color: inherit;
	}

	@media (max-width: 560px) {
		main {
			width: min(100% - 24px, 1180px);
		}
	}
</style>
