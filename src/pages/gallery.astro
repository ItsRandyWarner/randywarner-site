---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Gallery">
  <main class="max-w-3xl mx-auto px-4 py-10 space-y-16">

    <h1 class="text-xl font-medium">Gallery</h1>
    <p class="text-gray-700 leading-relaxed">This is a space for photographs I've taken along the way.<br/>
    Some are moments, some are experiments, some are just things that caught my eye.</p>

    <p>There's no single theme here — just attention, light, and curiosity.</p>
  </main>
</BaseLayout>
