---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Lab">
  <main class="max-w-3xl mx-auto px-4 py-10 space-y-16">

    <h1 class="text-xl font-medium">Lab</h1>
    <p class="text-gray-700 leading-relaxed">This is a space for experiments.</p>

    <p class="text-gray-700 leading-relaxed">Some things here are unfinished, some may change,
    and some are just ideas I wanted to try out.</p>

    <p class="text-gray-700 leading-relaxed">Peak curiosity. Minimal polish.</p>
  </main>
</BaseLayout>
