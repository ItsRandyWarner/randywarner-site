---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Randy Warner">
  <!-- Bright lobby wrapper -->
  <div class="-mx-6 -mt-6 sm:-mx-6 sm:-mt-8 md:-mx-6 md:-mt-10 rounded-none sm:rounded-3xl bg-gradient-to-b from-amber-50 via-rose-50 to-cyan-50 text-neutral-900 border border-black/5">
    <div class="relative overflow-hidden sm:rounded-3xl px-6 py-12 sm:px-10">
      <!-- playful background blobs -->
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute -top-28 left-6 h-72 w-72 rounded-full bg-fuchsia-400/35 blur-3xl rotate-12"></div>
        <div class="absolute -bottom-28 right-6 h-80 w-80 rounded-full bg-cyan-400/30 blur-3xl -rotate-6"></div>
        <div class="absolute top-1/3 left-1/2 h-56 w-56 rounded-full bg-lime-300/25 blur-3xl"></div>
      </div>

      <!-- little “sticker” pills for whimsy -->
      <div class="pointer-events-none absolute top-6 right-6 hidden sm:flex gap-2">
        <span class="rounded-full border border-black/10 bg-white/60 px-3 py-1 text-xs text-neutral-700 shadow-sm rotate-2">
          ✨ whimsical
        </span>
        <span class="rounded-full border border-black/10 bg-white/60 px-3 py-1 text-xs text-neutral-700 shadow-sm -rotate-2">
          🧪 lab mode
        </span>
      </div>

      <div class="relative">
        <p class="text-sm text-neutral-700">A reasonably organized creative mess</p>

        <h1 class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl">
          Randy Warner
        </h1>

        <p class="mt-4 max-w-2xl text-base leading-relaxed text-neutral-700">
          Photography, writing, and experiments. The front door stays easy to navigate —
          the back rooms get weird on purpose.
        </p>

        <div class="mt-7 flex flex-wrap items-center gap-3">
          <a
            href="/photography"
            class="rounded-xl border border-black/10 bg-white/60 px-4 py-2 text-sm font-medium shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
          >
            View photography
          </a>

          <a
            href="/lab"
            class="rounded-xl border border-fuchsia-500/25 bg-fuchsia-500/15 px-4 py-2 text-sm font-medium shadow-sm transition transform hover:-translate-y-0.5 hover:rotate-1 hover:bg-fuchsia-500/20 hover:shadow-md"
          >
            Enter the lab
          </a>

          <a
            href="/blog"
            class="px-3 py-2 text-sm text-neutral-700 underline decoration-black/20 underline-offset-4 hover:text-neutral-900"
          >
            Read writing →
          </a>
        </div>

        <div class="mt-8 flex flex-wrap gap-2 text-xs text-neutral-700">
          <span class="rounded-full border border-black/10 bg-white/60 px-3 py-1 shadow-sm">Portraits</span>
          <span class="rounded-full border border-black/10 bg-white/60 px-3 py-1 shadow-sm">Street</span>
          <span class="rounded-full border border-black/10 bg-white/60 px-3 py-1 shadow-sm">Low light</span>
          <span class="rounded-full border border-black/10 bg-white/60 px-3 py-1 shadow-sm">Comedy brain</span>
          <span class="rounded-full border border-black/10 bg-white/60 px-3 py-1 shadow-sm">Odd projects</span>
        </div>
      </div>

      <!-- cards -->
      <section class="relative mt-10 grid gap-6 md:grid-cols-3">
        <div class="rounded-2xl border border-black/10 bg-white/60 p-6 shadow-sm">
          <h2 class="text-lg font-semibold">Now</h2>
          <ul class="mt-3 space-y-2 text-sm text-neutral-700">
            <li>Building this site into a creative home base.</li>
            <li>Practicing portraits, street, and concert/low-light work.</li>
            <li>Shipping small experiments consistently.</li>
          </ul>
        </div>

        <div class="rounded-2xl border border-black/10 bg-white/60 p-6 shadow-sm md:translate-y-3">
          <h2 class="text-lg font-semibold">Featured</h2>

          <div class="mt-4 space-y-3">
            <a
              class="group block rounded-xl border border-black/10 bg-white/70 p-4 transition hover:-translate-y-0.5 hover:shadow-md"
              href="/photography"
            >
              <div class="flex items-center justify-between">
                <div class="font-medium">Photography</div>
                <span class="text-sm text-neutral-500 group-hover:text-neutral-700">→</span>
              </div>
              <div class="mt-1 text-sm text-neutral-700">Sets, studies, and experiments.</div>
            </a>

            <a
              class="group block rounded-xl border border-black/10 bg-white/70 p-4 transition hover:-translate-y-0.5 hover:shadow-md"
              href="/blog"
            >
              <div class="flex items-center justify-between">
                <div class="font-medium">Writing</div>
                <span class="text-sm text-neutral-500 group-hover:text-neutral-700">→</span>
              </div>
              <div class="mt-1 text-sm text-neutral-700">Thoughts, lessons, and stories.</div>
            </a>

            <a
              class="group block rounded-xl border border-black/10 bg-white/70 p-4 transition hover:-translate-y-0.5 hover:shadow-md"
              href="/lab"
            >
              <div class="flex items-center justify-between">
                <div class="font-medium">Creative Lab</div>
                <span class="text-sm text-neutral-500 group-hover:text-neutral-700">→</span>
              </div>
              <div class="mt-1 text-sm text-neutral-700">WIP ideas and weird prototypes.</div>
            </a>
          </div>
        </div>

        <div class="rounded-2xl border border-black/10 bg-white/60 p-6 shadow-sm">
          <h2 class="text-lg font-semibold">Connect</h2>
          <p class="mt-3 text-sm leading-relaxed text-neutral-700">
            Want to grab lunch and talk creativity, business, or odd projects?
          </p>

          <div class="mt-5 flex flex-col gap-3">
            <a
              href="/connect"
              class="inline-flex items-center justify-center rounded-xl border border-cyan-500/25 bg-cyan-400/15 px-4 py-2 text-sm font-medium shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
            >
              Lunch signup
            </a>
            <a
              href="/connect"
              class="inline-flex items-center justify-center rounded-xl border border-black/10 bg-white/70 px-4 py-2 text-sm text-neutral-800 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
            >
              Contact
            </a>
          </div>
        </div>
      </section>

      <p class="relative mt-10 text-sm text-neutral-600">
        This site will evolve in public. The lobby stays readable — the lab gets stranger.
      </p>
    </div>
  </div>
</BaseLayout>
