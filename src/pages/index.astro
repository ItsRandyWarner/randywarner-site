---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Randy Warner">
  <!-- HERO -->
  <section class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-b from-white/5 to-transparent p-10">
    <!-- glow blobs -->
    <div class="pointer-events-none absolute inset-0 opacity-60">
      <div class="absolute -top-24 left-8 h-64 w-64 rounded-full bg-fuchsia-500/20 blur-3xl"></div>
      <div class="absolute -bottom-24 right-8 h-64 w-64 rounded-full bg-cyan-400/20 blur-3xl"></div>
    </div>

    <div class="relative">
      <p class="text-sm text-white/70">Personal hub</p>

      <h1 class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl">
        Randy Warner
      </h1>

      <p class="mt-4 max-w-2xl text-base leading-relaxed text-white/80">
        Photography, writing, and creative experiments. The front door is tidy,
        the back rooms get weird.
      </p>

      <div class="mt-7 flex flex-wrap items-center gap-3">
        <a
          href="/photography"
          class="rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-sm font-medium hover:bg-white/10"
        >
          View photography
        </a>
        <a
          href="/lab"
          class="rounded-xl border border-fuchsia-400/30 bg-fuchsia-500/10 px-4 py-2 text-sm font-medium hover:bg-fuchsia-500/15"
        >
          Enter the lab
        </a>
        <a
          href="/blog"
          class="px-3 py-2 text-sm text-white/70 hover:text-white/90"
        >
          Read writing →
        </a>
      </div>

      <div class="mt-8 flex flex-wrap gap-2 text-xs text-white/50">
        <span class="rounded-full border border-white/10 bg-black/20 px-3 py-1">Portraits</span>
        <span class="rounded-full border border-white/10 bg-black/20 px-3 py-1">Street</span>
        <span class="rounded-full border border-white/10 bg-black/20 px-3 py-1">Low light</span>
        <span class="rounded-full border border-white/10 bg-black/20 px-3 py-1">Comedy brain</span>
        <span class="rounded-full border border-white/10 bg-black/20 px-3 py-1">Odd projects</span>
      </div>
    </div>
  </section>

  <!-- GRID -->
  <section class="mt-10 grid gap-6 md:grid-cols-3">
    <!-- NOW -->
    <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <h2 class="text-lg font-semibold">Now</h2>
      <ul class="mt-3 space-y-2 text-sm text-white/75">
        <li>Building this site into a creative home base.</li>
        <li>Practicing portraits, street, and concert/low-light work.</li>
        <li>Shipping small experiments consistently.</li>
      </ul>
    </div>

    <!-- FEATURED -->
    <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <h2 class="text-lg font-semibold">Featured</h2>

      <div class="mt-4 space-y-3">
        <a
          class="group block rounded-xl border border-white/10 bg-black/20 p-4 hover:bg-black/30"
          href="/photography"
        >
          <div class="flex items-center justify-between">
            <div class="text-white/90 font-medium">Photography</div>
            <span class="text-sm text-white/50 group-hover:text-white/70">→</span>
          </div>
          <div class="mt-1 text-sm text-white/65">Sets, studies, and experiments.</div>
        </a>

        <a
          class="group block rounded-xl border border-white/10 bg-black/20 p-4 hover:bg-black/30"
          href="/blog"
        >
          <div class="flex items-center justify-between">
            <div class="text-white/90 font-medium">Writing</div>
            <span class="text-sm text-white/50 group-hover:text-white/70">→</span>
          </div>
          <div class="mt-1 text-sm text-white/65">Thoughts, lessons, and stories.</div>
        </a>

        <a
          class="group block rounded-xl border border-white/10 bg-black/20 p-4 hover:bg-black/30"
          href="/lab"
        >
          <div class="flex items-center justify-between">
            <div class="text-white/90 font-medium">Creative Lab</div>
            <span class="text-sm text-white/50 group-hover:text-white/70">→</span>
          </div>
          <div class="mt-1 text-sm text-white/65">WIP ideas and weird prototypes.</div>
        </a>
      </div>
    </div>

    <!-- CONNECT -->
    <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
      <h2 class="text-lg font-semibold">Connect</h2>
      <p class="mt-3 text-sm leading-relaxed text-white/75">
        Want to grab lunch and talk creativity, business, or odd projects?
      </p>

      <div class="mt-5 flex flex-col gap-3">
        <a
          href="/connect"
          class="inline-flex items-center justify-center rounded-xl border border-cyan-300/30 bg-cyan-400/10 px-4 py-2 text-sm font-medium hover:bg-cyan-400/15"
        >
          Lunch signup
        </a>
        <a
          href="/connect"
          class="inline-flex items-center justify-center rounded-xl border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/80 hover:bg-white/10"
        >
          Contact
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTNOTE / TONE -->
  <section class="mt-10">
    <p class="text-sm text-white/55">
      This site will evolve in public. The lobby stays readable — the lab gets stranger.
    </p>
  </section>
</BaseLayout>
