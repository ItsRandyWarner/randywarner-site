---
import { Image } from "astro:assets";
import WritingCard from "../components/WritingCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import heroPhotoGrid from "../assets/homepage/hero-photo-grid.jpg";
import yasCastArtwork from "../assets/podcasts/the-yas-cast-artwork.jpg";
import { getPublishedWriting } from "../lib/writing";

const publishedWriting = await getPublishedWriting();
const homepageWriting = [
	...publishedWriting.filter((post) => post.data.featured),
	...publishedWriting.filter((post) => !post.data.featured),
].slice(0, 3);
const showExploreSection = import.meta.env.DEV;

const paths = [
	{
		label: "Photos",
		copy: "A future place for images, color, texture, and moments worth keeping.",
		status: "Later",
	},
	{
		label: "Projects",
		copy: "Creative experiments, odd ideas, useful things, and whatever keeps tugging at the sleeve.",
		status: "Emerging",
	},
	{
		label: "Shop",
		copy: "Eventually, a small shelf for inexpensive creative objects. Quietly secondary on purpose.",
		status: "Future",
	},
];
---

<BaseLayout
	title="Randy Warner"
	description="Randy Warner's personal site for writing, The YaS Cast, creative projects, photos, and curious things worth coming back to."
	current="home"
>
	<main id="top">
			<section class="hero" aria-labelledby="hero-title">
				<div class="hero-copy">
					<p class="eyebrow">A peek inside the mind of</p>
					<h1 id="hero-title">Randy Warner</h1>
						<p class="intro">
							A place for deep curiosity, practicing creativity,
							creating community, and sharing what I’m making along the way.
						</p>
					<div class="hero-actions" aria-label="Featured sections">
						<a class="button primary" href="#writing">Start exploring</a>
						<a class="button secondary" href="#podcast">Hear The YaS Cast</a>
					</div>
				</div>

				<div class="hero-art">
					<div class="hero-photo-card">
						<Image
							src={heroPhotoGrid}
							alt="A personal photo collage for Randy Warner's homepage"
							class="hero-photo-grid"
							width={800}
							height={1000}
							priority
						/>
					</div>
				</div>
			</section>

			<section class="section writing-section" id="writing" aria-labelledby="writing-title">
				<div class="section-heading">
					<p class="eyebrow">Writing</p>
					<h2 id="writing-title">Sit with me as I explore my own mind.</h2>
						<p>
							Quick notes, thoughtful essays, stories, and hopefully something useful about life,
							relationships, spirituality, and being human.
						</p>
				</div>

				{
					homepageWriting.length > 0 ? (
						<div class="writing-grid">
							{homepageWriting.map((post) => (
								<WritingCard post={post} />
							))}
						</div>
					) : (
						<div class="writing-empty">
							<p>The writing room is open. The first public pieces are still being drafted.</p>
							<a href="/writing/">Visit writing</a>
						</div>
					)
				}
			</section>

			<section class="podcast" id="podcast" aria-labelledby="podcast-title">
				<div class="podcast-art">
					<Image
						src={yasCastArtwork}
						alt="The YaS Cast podcast artwork"
						class="podcast-image"
						width={720}
						height={720}
						loading="lazy"
					/>
				</div>
				<div class="podcast-copy">
					<p class="eyebrow">Podcast</p>
					<h2 id="podcast-title">The YaS Cast</h2>
					<p>
						I started The YaS Cast as a way to connect with people and explore the
						community around me a little more deeply. The show is really just an
						excuse to have better conversations with the people who make Yuba-Sutter
						what it is.
					</p>
					<div class="podcast-links">
						<a
							class="button primary"
							href="/podcasts/"
						>
							Visit Podcasts
						</a>
						<a
							class="button secondary"
							href="/podcasts/request/?podcast=the-yas-cast"
						>
							Send an idea
						</a>
					</div>
				</div>
			</section>

			{
				showExploreSection && (
					<section class="section explore-section" id="explore" aria-labelledby="explore-title">
						<div class="section-heading split">
							<div>
								<p class="eyebrow">Explore more</p>
								<h2 id="explore-title">Not everything needs to be finished before it has a doorway.</h2>
							</div>
							<p>
								These paths are early markers for where the site can grow after the homepage
								finds its rhythm.
							</p>
						</div>

						<div class="path-grid">
							{paths.map((path) => (
								<article class="path-card">
									<span>{path.status}</span>
									<h3>{path.label}</h3>
									<p>{path.copy}</p>
								</article>
							))}
						</div>
					</section>
				)
			}

			<section class="now-callout" aria-label="Now page callout">
				<p>
					If you’re curious what’s getting my attention lately, I made a <a href="/now/">/now page</a>.
				</p>
			</section>
	</main>
</BaseLayout>

<style>
	main {
		width: min(1180px, calc(100% - 32px));
		margin: 0 auto;
		padding: 22px 0 56px;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
		gap: clamp(28px, 5vw, 68px);
		align-items: center;
		min-height: clamp(560px, calc(100svh - 92px), 760px);
		padding: 24px 0 clamp(32px, 5vw, 44px);
	}

	.hero-copy {
		max-width: 680px;
	}

	.eyebrow {
		margin: 0 0 14px;
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		text-wrap: pretty;
	}

	h1 {
		max-width: 11ch;
		margin: 0;
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(4.8rem, 11vw, 9.6rem);
		line-height: 0.82;
		font-weight: 900;
	}

	h2 {
		max-width: 860px;
		margin: 0;
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(1.75rem, 3vw, 2.75rem);
		line-height: 1.04;
	}

	h3 {
		margin: 0;
		font-size: clamp(1.35rem, 3vw, 2.05rem);
		line-height: 1.02;
	}

	.intro {
		max-width: 660px;
		margin: 26px 0 0;
		font-size: clamp(1.18rem, 2.6vw, 1.75rem);
		line-height: 1.35;
	}

	.hero-actions,
	.podcast-links {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 28px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 48px;
		padding: 12px 18px;
		border: 2px solid var(--ink);
		font-weight: 900;
		text-decoration: none;
		transition:
			transform 160ms ease,
			box-shadow 160ms ease;
	}

	.button:hover,
	.button:focus-visible {
		transform: translate(-2px, -2px);
		box-shadow: 5px 5px 0 var(--ink);
	}

	.primary {
		background: var(--red);
		color: #fff9ec;
	}

	.secondary {
		background: #fff9ec;
	}

	.hero-art {
		justify-self: stretch;
	}

	.hero-photo-card {
		position: relative;
		display: grid;
		aspect-ratio: 4 / 5;
		min-height: 460px;
		padding: clamp(18px, 3vw, 28px);
		overflow: hidden;
		border: 3px solid var(--ink);
		background:
			linear-gradient(135deg, rgba(255, 249, 236, 0.72) 0 34%, transparent 34%),
			repeating-linear-gradient(90deg, rgba(32, 23, 19, 0.08) 0 2px, transparent 2px 18px),
			var(--blue);
		box-shadow: var(--shadow);
	}

	.hero-photo-card::after {
		position: absolute;
		inset: clamp(18px, 3vw, 28px);
		content: "";
		pointer-events: none;
		border: 3px solid var(--ink);
		box-shadow: inset 0 0 0 1px rgba(255, 249, 236, 0.35);
	}

	:global(.hero-photo-grid) {
		display: block;
		width: 100%;
		height: 100%;
		min-height: 0;
		object-fit: cover;
	}

	.section {
		scroll-margin-top: 96px;
		padding: clamp(40px, 7vw, 76px) 0;
		border-top: 2px solid var(--ink);
	}

	.section-heading {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(260px, 0.55fr);
		column-gap: clamp(22px, 5vw, 60px);
		row-gap: 0;
		align-items: end;
		margin-bottom: 28px;
	}

	.section-heading > .eyebrow {
		grid-column: 1 / -1;
		margin-bottom: 14px;
	}

	.section-heading > p,
	.split > p {
		margin: 0;
		font-size: 1.05rem;
		line-height: 1.65;
	}

	.writing-grid,
	.path-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
	}

	.path-card {
		display: flex;
		flex-direction: column;
		min-height: 260px;
		padding: 22px;
		border: 2px solid var(--ink);
		background: var(--paper-deep);
		box-shadow: 6px 6px 0 rgba(32, 23, 19, 0.12);
	}

	.path-card span {
		display: inline-flex;
		width: fit-content;
		padding: 5px 8px;
		border: 1px solid var(--ink);
		background: var(--yellow);
		font-size: 0.74rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.path-card p {
		margin: 18px 0 0;
		line-height: 1.55;
	}

	.podcast {
		scroll-margin-top: 96px;
		display: grid;
		grid-template-columns: minmax(260px, 0.6fr) minmax(0, 1fr);
		gap: clamp(22px, 5vw, 56px);
		align-items: stretch;
		padding: clamp(28px, 5vw, 52px);
		border: 3px solid var(--ink);
		background:
			linear-gradient(90deg, rgba(255, 249, 236, 0.88), rgba(255, 249, 236, 0.7)),
			repeating-linear-gradient(90deg, var(--green) 0 18px, var(--blue) 18px 36px);
		box-shadow: var(--shadow);
	}

	.now-callout {
		margin-top: clamp(18px, 3vw, 30px);
		padding: 16px 22px;
		border: 3px solid var(--ink);
		background:
			linear-gradient(180deg, rgba(245, 232, 190, 0.92), rgba(245, 232, 190, 0.92)),
			repeating-linear-gradient(
				90deg,
				rgba(242, 189, 52, 0.3) 0 18px,
				rgba(31, 111, 139, 0.16) 18px 36px
			);
		box-shadow: var(--shadow);
	}

	.now-callout p {
		margin: 0;
		font-size: 1.02rem;
		font-weight: 800;
		line-height: 1.4;
		text-align: center;
		white-space: nowrap;
	}

	.now-callout a {
		font-weight: 900;
	}

	.podcast-art {
		display: grid;
		place-items: center;
		width: 100%;
		max-width: 420px;
		aspect-ratio: 1;
		border: 3px solid var(--ink);
		overflow: hidden;
		background: var(--ink);
		box-shadow: 8px 8px 0 rgba(32, 23, 19, 0.14);
		transform: rotate(-2deg);
	}

	:global(.podcast-image) {
		display: block;
		width: 100%;
		height: 100%;
		max-width: 100%;
		object-fit: cover;
	}

	.podcast-copy {
		align-self: center;
		max-width: 680px;
	}

	.podcast-copy p:not(.eyebrow) {
		margin: 24px 0 0;
		font-size: clamp(1.08rem, 2vw, 1.35rem);
		line-height: 1.55;
	}

	.path-card:nth-child(2) {
		background: #cfe0d0;
	}

	.path-card:nth-child(3) {
		background: #f2d36f;
	}

	.writing-empty {
		max-width: 680px;
		padding: 24px;
		border: 2px solid var(--ink);
		background: #fff9ec;
		box-shadow: 6px 6px 0 rgba(32, 23, 19, 0.12);
	}

	.writing-empty p {
		margin: 0;
		font-size: 1.08rem;
		line-height: 1.65;
	}

	.writing-empty a {
		display: inline-flex;
		margin-top: 18px;
		font-weight: 900;
	}

	@media (max-width: 860px) {
		.hero,
		.section-heading,
		.podcast {
			grid-template-columns: 1fr;
		}

		.hero {
			min-height: auto;
			padding-top: 34px;
		}

		.hero-photo-card {
			min-height: 380px;
		}

		.writing-grid,
		.path-grid {
			grid-template-columns: 1fr;
		}

	}

	@media (max-width: 560px) {
		main {
			width: min(100% - 24px, 1180px);
			padding-top: 10px;
		}

		.hero-actions,
		.podcast-links {
			align-items: stretch;
			flex-direction: column;
		}

		.button {
			width: 100%;
		}

		h1 {
			font-size: clamp(4rem, 21vw, 6rem);
		}

		.hero-photo-card {
			min-height: 320px;
			padding: 14px;
		}

		.hero-photo-card::after {
			inset: 14px;
		}

		.path-card,
		.writing-empty,
		.podcast,
		.now-callout {
			padding: 18px;
		}

		.path-card {
			min-height: 220px;
		}

		.now-callout p {
			white-space: normal;
		}
	}
</style>
