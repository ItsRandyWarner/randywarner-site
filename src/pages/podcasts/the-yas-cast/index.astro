---
import { Image } from "astro:assets";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import yasCastArtwork from "../../../assets/podcasts/the-yas-cast-artwork.jpg";
import { getYasCastEpisodes, starterEpisodeCards, yasCastLinks } from "../../../lib/yas-cast";

const episodes = await getYasCastEpisodes();
const latestEpisode = episodes[0];
const recentEpisodes = episodes.slice(0, 8);
const starterCards = starterEpisodeCards(episodes);

const formatEpisodeDate = (value: string) =>
	new Intl.DateTimeFormat("en", {
		month: "long",
		day: "numeric",
		year: "numeric",
		timeZone: "UTC",
	}).format(new Date(value));
---

<BaseLayout
	title="The YaS Cast | Randy Warner"
	description="The YaS Cast is Randy Warner's podcast for better conversations with people in and around Yuba-Sutter."
	current="podcast"
>
	<main>
		<a class="back-link" href="/podcasts/">Back to podcasts</a>

		<section class="show-hero" aria-labelledby="show-title">
			<div class="hero-copy">
				<p class="eyebrow">The YaS Cast</p>
				<h1 id="show-title">Better conversations with the people who make Yuba-Sutter what it is.</h1>
				<p>
					I started The YaS Cast because I wanted a real excuse to connect with people,
					ask better questions, and understand the community around me more deeply.
				</p>
				<div class="action-row" aria-label="Listen to The YaS Cast">
					<a class="button primary" href={yasCastLinks.spotify} target="_blank" rel="noreferrer">Spotify</a>
					<a class="button secondary" href={yasCastLinks.apple} target="_blank" rel="noreferrer">
						Apple Podcasts
					</a>
					<a class="button ghost" href={yasCastLinks.request}>Suggest an idea</a>
				</div>
			</div>

			<div class="hero-art">
				<Image
					src={yasCastArtwork}
					alt="The YaS Cast podcast artwork"
					width={900}
					height={900}
					loading="eager"
				/>
			</div>
		</section>

		{
			latestEpisode && (
				<section class="latest-panel" aria-labelledby="latest-title">
					<div>
						<p class="eyebrow">Latest Episode</p>
						<h2 id="latest-title">{latestEpisode.title}</h2>
					</div>
					<div class="episode-copy">
						{
							latestEpisode.image && (
								<img
									class="episode-artwork latest-artwork"
									src={latestEpisode.image}
									alt={`${latestEpisode.title} episode artwork`}
									width="320"
									height="320"
								/>
							)
						}
						<p class="episode-meta">
							{latestEpisode.episodeNumber && <>Episode {latestEpisode.episodeNumber} · </>}
							{formatEpisodeDate(latestEpisode.publishedAt)}
							{latestEpisode.duration && <> · {latestEpisode.duration}</>}
						</p>
						<p>
							{latestEpisode.description ||
								"Fresh from the feed. Press play, meet the person, and see where the conversation goes."}
						</p>
						<a class="text-link" href={latestEpisode.url} target="_blank" rel="noreferrer">
							Listen to this episode
						</a>
					</div>
				</section>
			)
		}

		<section class="section-block" aria-labelledby="start-title">
			<div class="section-heading">
				<p class="eyebrow">Start Here</p>
				<h2 id="start-title">A few good first listens.</h2>
				<p>
					Curated episodes from my favorite conversations. Rotates weekly. If you like these, there's a good chance you'll like the rest of the show.
				</p>
			</div>

			<div class="starter-grid" data-starter-pool>
				{
					starterCards.map(({ episode, index, note, title }) => (
						<article class:list={["starter-card", index < 3 && "is-visible"]} data-starter-card data-starter-index={index}>
							{episode?.image && (
								<img
									class="episode-artwork starter-artwork"
									src={episode.image}
									alt={`${episode.title} episode artwork`}
									width="240"
									height="240"
									loading="lazy"
								/>
							)}
							<p class="episode-kicker">{episode?.episodeNumber ? `Episode ${episode.episodeNumber}` : "Randy pick"}</p>
							<h3>{episode?.title ?? title}</h3>
							<p>{note}</p>
							{episode && (
								<a class="text-link" href={episode.url} target="_blank" rel="noreferrer">
									Listen
								</a>
							)}
						</article>
					))
				}
			</div>
		</section>

		<section class="section-block" aria-labelledby="recent-title">
			<div class="section-heading">
				<p class="eyebrow">Recent Conversations</p>
				<h2 id="recent-title">From the feed.</h2>
				<p>
					Here are a few of the most recent episodes.
				</p>
			</div>

			<div class="episode-list">
				{
					recentEpisodes.map((episode) => (
						<article class="episode-row">
							<div class="episode-row-main">
								{episode.image && (
									<img
										class="episode-thumb"
										src={episode.image}
										alt={`${episode.title} episode artwork`}
										width="96"
										height="96"
										loading="lazy"
									/>
								)}
								<div>
									<p class="episode-kicker">
										{episode.episodeNumber ? `Episode ${episode.episodeNumber}` : "Episode"} ·{" "}
										{formatEpisodeDate(episode.publishedAt)}
									</p>
									<h3>{episode.title}</h3>
									{episode.description && <p>{episode.description}</p>}
								</div>
							</div>
							<a class="button secondary small" href={episode.url} target="_blank" rel="noreferrer">
								Listen
							</a>
						</article>
					))
				}
			</div>
		</section>

		<section class="request-panel" aria-labelledby="request-title">
			<div>
				<p class="eyebrow">Have an idea?</p>
				<h2 id="request-title">Send me a guest, a topic, or a reason you should be on the show.</h2>
			</div>
			<div class="request-actions">
				<a class="button primary" href="/podcasts/request/?podcast=the-yas-cast&type=guest_suggestion">
					Suggest a guest
				</a>
				<a class="button secondary" href="/podcasts/request/?podcast=the-yas-cast&type=topic_suggestion">
					Suggest a topic
				</a>
				<a class="button secondary" href="/podcasts/request/?podcast=the-yas-cast&type=guest_request">
					Request to be a guest
				</a>
			</div>
		</section>
	</main>
</BaseLayout>

<script is:inline>
	const starterCards = Array.from(document.querySelectorAll("[data-starter-card]"));
	const visibleStarterCount = 3;

	const currentWeekSeed = () => {
		const now = new Date();
		const yearStart = Date.UTC(now.getUTCFullYear(), 0, 1);
		const today = Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate());
		const dayOfYear = Math.floor((today - yearStart) / 86400000);
		return now.getUTCFullYear() * 100 + Math.floor(dayOfYear / 7);
	};

	const seededShuffle = (items, seed) => {
		const shuffled = [...items];
		let state = seed >>> 0;
		const next = () => {
			state = (state * 1664525 + 1013904223) >>> 0;
			return state / 4294967296;
		};

		for (let index = shuffled.length - 1; index > 0; index -= 1) {
			const swapIndex = Math.floor(next() * (index + 1));
			[shuffled[index], shuffled[swapIndex]] = [shuffled[swapIndex], shuffled[index]];
		}

		return shuffled;
	};

	if (starterCards.length > visibleStarterCount) {
		const selectedIndexes = new Set(
			seededShuffle(
				starterCards.map((_, index) => index),
				currentWeekSeed(),
			).slice(0, visibleStarterCount),
		);

		starterCards.forEach((card, index) => {
			card.classList.toggle("is-visible", selectedIndexes.has(index));
		});
	}
</script>

<style>
	main {
		width: min(1180px, calc(100% - 32px));
		margin: 0 auto;
		padding: clamp(34px, 7vw, 72px) 0 72px;
	}

	.back-link {
		display: inline-flex;
		margin-bottom: 28px;
		font-weight: 900;
	}

	.eyebrow {
		margin: 0 0 12px;
		font-size: 0.78rem;
		font-weight: 900;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		text-wrap: pretty;
	}

	h1,
	h2,
	h3 {
		margin: 0;
		font-family: Georgia, "Times New Roman", serif;
		line-height: 1;
	}

	h1 {
		max-width: 16ch;
		font-size: clamp(2.45rem, 5.8vw, 5.8rem);
	}

	h2 {
		font-size: clamp(1.8rem, 3.4vw, 3.35rem);
	}

	h3 {
		font-size: clamp(1.25rem, 2vw, 1.75rem);
	}

	.show-hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 0.58fr);
		gap: clamp(28px, 5vw, 68px);
		align-items: center;
		padding-bottom: clamp(38px, 6vw, 72px);
		border-bottom: 3px solid var(--ink);
	}

	.hero-copy > p:not(.eyebrow) {
		max-width: 680px;
		margin: 24px 0 0;
		font-size: clamp(1.05rem, 1.6vw, 1.22rem);
		line-height: 1.7;
	}

	.hero-art {
		aspect-ratio: 1;
		overflow: hidden;
		border: 3px solid var(--ink);
		background: var(--ink);
		box-shadow: var(--shadow);
	}

	.hero-art :global(img) {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.action-row,
	.request-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 28px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 48px;
		padding: 12px 18px;
		border: 2px solid var(--ink);
		font-weight: 900;
		text-decoration: none;
		transition:
			transform 160ms ease,
			box-shadow 160ms ease;
	}

	.button:hover,
	.button:focus-visible {
		transform: translate(-2px, -2px);
		box-shadow: 5px 5px 0 var(--ink);
	}

	.primary {
		background: var(--red);
		color: #fff9ec;
	}

	.secondary,
	.ghost {
		background: #fff9ec;
		color: var(--ink);
	}

	.ghost {
		background: transparent;
	}

	.small {
		min-height: 42px;
		padding: 9px 14px;
	}

	.latest-panel,
	.request-panel {
		display: grid;
		grid-template-columns: minmax(0, 0.86fr) minmax(280px, 1fr);
		gap: clamp(22px, 5vw, 58px);
		align-items: start;
		margin-top: clamp(34px, 6vw, 72px);
		padding: clamp(24px, 4vw, 38px);
		border: 2px solid var(--ink);
		background:
			linear-gradient(135deg, rgba(242, 189, 52, 0.16), rgba(31, 111, 139, 0.08)),
			rgba(255, 255, 255, 0.62);
		box-shadow: 8px 8px 0 rgba(32, 23, 19, 0.1);
	}

	.episode-copy p,
	.section-heading p,
	.starter-card p,
	.episode-row p,
	.request-panel p {
		line-height: 1.65;
	}

	.episode-copy p {
		margin: 0 0 16px;
	}

	.episode-meta,
	.episode-kicker {
		margin: 0 0 10px;
		color: rgba(32, 23, 19, 0.68);
		font-size: 0.88rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.text-link {
		font-weight: 900;
	}

	.section-block {
		margin-top: clamp(44px, 7vw, 84px);
	}

	.section-heading {
		max-width: 760px;
		margin-bottom: 24px;
	}

	.section-heading p:not(.eyebrow) {
		margin: 18px 0 0;
	}

	.starter-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
	}

	.starter-card {
		display: none;
		align-content: start;
		gap: 12px;
		min-height: 260px;
		padding: 20px;
		border: 2px solid var(--ink);
		background: rgba(255, 255, 255, 0.72);
		box-shadow: 7px 7px 0 rgba(32, 23, 19, 0.08);
	}

	.starter-card.is-visible {
		display: grid;
	}

	.starter-card p {
		margin: 0;
	}

	.episode-artwork,
	.episode-thumb {
		display: block;
		aspect-ratio: 1;
		object-fit: cover;
		border: 2px solid var(--ink);
		background: #fff9ec;
	}

	.latest-artwork {
		width: min(100%, 220px);
		height: auto;
		margin-bottom: 18px;
		box-shadow: 6px 6px 0 rgba(32, 23, 19, 0.1);
	}

	.starter-artwork {
		width: min(100%, 150px);
		height: auto;
		margin-bottom: 2px;
	}

	.episode-list {
		display: grid;
		border-top: 2px solid var(--ink);
	}

	.episode-row {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 18px;
		align-items: center;
		padding: 20px 0;
		border-bottom: 1px solid rgba(32, 23, 19, 0.22);
	}

	.episode-row-main {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 14px;
		align-items: center;
	}

	.episode-thumb {
		width: 76px;
		height: 76px;
	}

	.episode-row h3 {
		margin-bottom: 10px;
	}

	.episode-row p {
		margin: 0;
	}

	.request-panel {
		align-items: center;
		background:
			repeating-linear-gradient(-18deg, rgba(84, 120, 77, 0.12) 0 7px, transparent 7px 20px),
			rgba(255, 255, 255, 0.68);
	}

	.request-actions {
		flex-direction: column;
		align-items: flex-end;
		margin-top: 0;
	}

	.request-actions .button {
		width: min(100%, 280px);
	}

	@media (max-width: 860px) {
		.show-hero,
		.latest-panel,
		.request-panel {
			grid-template-columns: 1fr;
		}

		.hero-art {
			max-width: 520px;
		}

		.starter-grid {
			grid-template-columns: 1fr;
		}

		.request-actions {
			align-items: flex-start;
		}
	}

	@media (max-width: 560px) {
		main {
			width: min(100% - 24px, 1180px);
		}

		.action-row,
		.request-actions {
			flex-direction: column;
			align-items: stretch;
		}

		.button {
			width: 100%;
		}

		.request-actions .button {
			width: 100%;
		}

		.latest-panel,
		.request-panel {
			padding: 18px;
		}

		.episode-row {
			grid-template-columns: 1fr;
		}

		.episode-row-main {
			grid-template-columns: 1fr;
		}
	}
</style>
