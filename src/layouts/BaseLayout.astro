---
import "../styles/global.css";
import "../components/Analytics.astro"

const { title = "Lobby" } = Astro.props;

// time-of-day (site-wide)
const hour = new Date().getHours();
let timeOfDay = "day";
if (hour >= 5 && hour < 11) timeOfDay = "morning";
else if (hour >= 11 && hour < 17) timeOfDay = "afternoon";
else if (hour >= 17 && hour < 22) timeOfDay = "evening";
else timeOfDay = "late-night";

// nav (existing)
const normalizePath = (path: string): string => {
  if (!path) return "/";
  const withSlash = path.startsWith("/") ? path : `/${path}`;
  return withSlash !== "/" ? withSlash.replace(/\/+$/, "") : "/";
};
const pathname = normalizePath(Astro.url.pathname);

const nav: { href: string; label: string }[] = [
  { href: "/", label: "Lobby" },
  { href: "/gallery", label: "Gallery" },
  { href: "/study", label: "Study" },
  { href: "/lab", label: "Lab" },
  { href: "/common-room", label: "Common Room" },
  { href: "/now", label: "Now" },
];

const isActive = (href: string): boolean => {
  const target = normalizePath(href);
  if (target === "/") return pathname === "/";
  return pathname === target || pathname.startsWith(`${target}/`);
};

// time-of-day whisper (except on study pages)
const timeWhisper =
  timeOfDay === "morning" ? "Happy you're here early." :
  timeOfDay === "afternoon" ? "Midday momentum." :
  timeOfDay === "evening" ? "Evening hours." :
  "Late night vibes.";

const showTimeWhisper = !(pathname === "/study" || pathname.startsWith("/study/"));

const isDeepLateNight =
  timeOfDay === "late-night" && (hour >= 0 && hour < 4);

const lateNightEgg = "Somebody likes to party.";

// seasonal whisper
const month = new Date().getMonth(); // 0=Jan ... 11=Dec

const season =
  (month === 11 || month === 0 || month === 1) ? "winter" :
  (month >= 2 && month <= 4) ? "spring" :
  (month >= 5 && month <= 7) ? "summer" :
  "fall";

const seasonWhisper =
  season === "winter" ? " Cold air, clear thoughts." :
  season === "spring" ? "Fresh cut grass, birds chirpin'." :
  season === "summer" ? "Drink some water." :
  "Sweater weather.";

const presenceWhisper = `${timeWhisper} ${seasonWhisper}`;

// angel number easter egg
const now = new Date();
const minutes = now.getMinutes();
const is222 = hour === 2 && minutes === 22;
const is1111 = hour === 11 && minutes === 11;

const showEasterEgg = (is222 || is1111) && showTimeWhisper;

const easterEggText = is222
  ? "psst...2:22. Harmonize your life."
  : "psst...11:11. Make a wish.";

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body data-time={timeOfDay} data-season={season}>
    <header class="border-b">
      <nav aria-label="Primary" class="max-w-3xl mx-auto px-4 py-3">
        <ul class="flex gap-4 text-sm">
          {nav.map((item) => (
            <li>
              <a
                href={item.href}
                aria-current={isActive(item.href) ? "page" : undefined}
                class="
                  text-gray-700
                  hover:text-black
                  aria-[current=page]:font-medium
                  aria-[current=page]:text-black
                "
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <slot />

    <footer class="max-w-3xl mx-auto px-4 py-10 space-y-2">
      <p class="text-sm text-gray-700">Built slowly, with care. Occasionally strange.</p>

      {showTimeWhisper && (
        <p class="text-xs text-gray-500">{presenceWhisper}</p>
      )}
      {showEasterEgg && (
        <p class="text-[11px] text-gray-400">{easterEggText}</p>
      )}
      {isDeepLateNight && showTimeWhisper && (
        <p class="text-[11px] text-gray-400">{lateNightEgg}</p>
      )}

    </footer>
  </body>
</html>
