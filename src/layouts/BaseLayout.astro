---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";

type CurrentPage = "home" | "writing" | "podcast" | "";
type SocialType = "website" | "article";

const {
	title,
	description,
	current = "",
	image = "/social-preview.png",
	type = "website",
} = Astro.props as {
	title: string;
	description: string;
	current?: CurrentPage;
	image?: string;
	type?: SocialType;
};

const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const socialImageUrl = Astro.site ? new URL(image, Astro.site).toString() : image;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" href="/favicon-32.png" />
		<link rel="icon" href="/favicon.ico" sizes="32x32" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
		<meta property="og:site_name" content="Randy Warner" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={type} />
		{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
		<meta property="og:image" content={socialImageUrl} />
		<meta
			property="og:image:alt"
			content="A colorful preview card for Randy Warner's personal creative site."
		/>
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImageUrl} />
		<meta
			name="twitter:image:alt"
			content="A colorful preview card for Randy Warner's personal creative site."
		/>
		<title>{title}</title>
	</head>
	<body>
		<SiteHeader current={current} />
		<slot />
		<SiteFooter />
	</body>
</html>

<style is:global>
	:root {
		--ink: #201713;
		--paper: #f8f1e3;
		--paper-deep: #eadbbf;
		--blue: #1f6f8b;
		--red: #d94b3d;
		--yellow: #f2bd34;
		--green: #54784d;
		--pink: #e88fa2;
		--border: rgba(32, 23, 19, 0.22);
		--shadow: 10px 10px 0 rgba(32, 23, 19, 0.12);
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
		color: var(--ink);
		background: var(--paper);
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-width: 320px;
		background:
			linear-gradient(90deg, rgba(32, 23, 19, 0.035) 1px, transparent 1px),
			linear-gradient(rgba(32, 23, 19, 0.035) 1px, transparent 1px),
			var(--paper);
		background-size: 32px 32px;
	}

	a {
		color: inherit;
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.18em;
	}
</style>
