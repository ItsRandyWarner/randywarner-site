---
import StickyNav from "../components/StickyNav.astro";
import PatternBackground from "../components/PatternBackground.astro";

const { title = "Home" } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <PatternBackground />
    <StickyNav />
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root{
    --ink:#151515;
    --paper:#f4f0e8;
    --border: rgba(0,0,0,.14);
    --shadow: 0 10px 30px rgba(0,0,0,.10);
    --shadow-soft: 0 6px 18px rgba(0,0,0,.10);
    --radius: 18px;
    --max: 1120px;

    --hero-warm:#f2b07b;
    --hero-cool:#d7e4ff;
    --hero-neutral:#efe8dc;

    --menu-bg: rgba(245, 242, 234, 0.92);
  }

  *{ box-sizing:border-box; }

  body{
    margin:0;
    color:var(--ink);
    background:var(--paper);
    font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Arial;
  }

  .wrap{ width:min(var(--max), calc(100% - 40px)); margin-inline:auto; }
</style>