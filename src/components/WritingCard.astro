---
import type { WritingPost } from "../lib/writing";
import { formatWritingDate, writingTypeLabel, writingUrl } from "../lib/writing";

const { post, featured = false } = Astro.props as {
	post: WritingPost;
	featured?: boolean;
};

const url = writingUrl(post);
---

<article class:list={["post-card", { "featured-card": featured }]}>
	{
		post.data.image && (
			<a class="post-image" href={url} aria-label={`Read ${post.data.title}`}>
				<img src={post.data.image.src} alt={post.data.image.alt} loading="lazy" />
			</a>
		)
	}
	<div class="post-body">
		<div class="post-meta">
			<span>{writingTypeLabel(post.data.type)}</span>
			<time datetime={post.data.date.toISOString()}>{formatWritingDate(post.data.date)}</time>
		</div>
		<h3>
			<a href={url}>{post.data.title}</a>
		</h3>
		<p>{post.data.description}</p>
		<div class="post-footer">
			<div class="topic-list">
				{post.data.topics.map((topic) => <span>{topic}</span>)}
			</div>
			<a class="read-link" href={url}>Read</a>
		</div>
	</div>
</article>

<style>
	.post-card {
		display: flex;
		flex-direction: column;
		min-height: 300px;
		overflow: hidden;
		border: 2px solid var(--ink);
		background: #fff9ec;
		box-shadow: 6px 6px 0 rgba(32, 23, 19, 0.12);
		transition:
			box-shadow 160ms ease,
			transform 160ms ease;
	}

	.post-card:focus-within,
	.post-card:hover {
		transform: translate(-2px, -2px);
		box-shadow: 10px 10px 0 rgba(32, 23, 19, 0.16);
	}

	.post-card:nth-child(2n) {
		background: var(--paper-deep);
	}

	.post-card:nth-child(3n) {
		background: #f4d9df;
	}

	.featured-card {
		min-height: 260px;
		background: var(--green);
		color: #fff9ec;
	}

	.post-image {
		display: block;
		aspect-ratio: 16 / 9;
		max-height: 220px;
		overflow: hidden;
		border-bottom: 2px solid var(--ink);
		background:
			repeating-linear-gradient(-18deg, rgba(32, 23, 19, 0.08) 0 3px, transparent 3px 17px),
			var(--paper-deep);
	}

	.featured-card .post-image {
		max-height: 320px;
	}

	.post-image img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.post-body {
		display: flex;
		flex: 1;
		flex-direction: column;
		padding: 22px;
	}

	.post-meta,
	.topic-list {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.post-meta {
		margin-bottom: 22px;
	}

	.post-meta span,
	.topic-list span {
		display: inline-flex;
		width: fit-content;
		padding: 5px 8px;
		border: 1px solid var(--ink);
		color: var(--ink);
		font-size: 0.74rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.post-meta span {
		background: var(--yellow);
	}

	.topic-list span {
		background: #cfe0d0;
	}

	.post-meta time {
		padding: 5px 0;
		font-size: 0.86rem;
		font-weight: 800;
	}

	h3 {
		margin: 0;
		font-size: clamp(1.35rem, 3vw, 2.2rem);
		line-height: 1.05;
		text-wrap: pretty;
	}

	p {
		margin: 18px 0 22px;
		font-size: 1.08rem;
		line-height: 1.65;
		text-wrap: pretty;
	}

	.post-footer {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 16px;
		margin-top: auto;
	}

	.read-link {
		flex: 0 0 auto;
		font-weight: 900;
	}

	@media (max-width: 560px) {
		.post-body {
			padding: 18px;
		}
	}
</style>
